# CEO AI (Expo) — public client environment variables.
# These are EXPO_PUBLIC_* values that get inlined into the app bundle at build
# time. They are PUBLIC by design (safe to ship in the client); the real
# security boundary is Supabase RLS + server-side subscription validation.
#
# These values are already set in eas.json for EAS builds.
# For local dev on Replit they are injected automatically from project secrets.

# Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://naodvygilgdefdjcmcuf.supabase.co

# Supabase anon (publishable) key
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5hb2R2eWdpbGdkZWZkamNtY3VmIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE2Njk2MTQsImV4cCI6MjA5NzI0NTYxNH0.iKMa27KmY8vXlQfm5VGILVgvsjXwFTeboteUiYgOvHQ

# RevenueCat iOS public SDK key
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_JmDJKkSTAdrtwziTnOfuxQbwAtK

# Host of the api-server (no protocol) — already baked into eas.json
